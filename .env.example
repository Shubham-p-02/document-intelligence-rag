# Required for chat and RAGAS evaluator LLM (Groq)
GROQ_API_KEY=

# Optional overrides
GROQ_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=.chroma_index
COLLECTION_NAME=documents

# Semantic chunking (see README)
SEMANTIC_BREAKPOINT_THRESHOLD_TYPE=percentile
SEMANTIC_BREAKPOINT_AMOUNT_THRESHOLD=95
CHUNK_OVERLAP_CHARS=120

# Retrieval defaults
RAG_TOP_K=4
# Max L2 distance (Chroma); typical range ~0.8–2.0 for MiniLM-normalized vectors
RAG_SIMILARITY_THRESHOLD=1.6
